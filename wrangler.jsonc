{
  "$schema": "node_modules/wrangler/config-schema.json",
  // Worker name → becomes the subdomain: me.alejandrofranks.workers.dev
  // Change this string to rename the URL slug.
  "name": "me",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-29",
  "vars": {
    "GITHUB_USER": "alejandrofrank",
    "LEETCODE_USER": "alexfrank"
  },
  "observability": {
    "enabled": true
  }
}
